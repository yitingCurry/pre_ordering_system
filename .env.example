# Backend (Render / local)
PORT=8010
DB_PATH=./database/restaurant.db
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# 到 https://aistudio.google.com/apikey 申請
# Rich Menu 腳本（npm run line:richmenu）
LIFF_ID=
CUSTOMER_URL=https://your-app.vercel.app
# CUSTOMER_LIFF_URL=https://liff.line.me/your-liff-id
# RICH_MENU_IMAGE_PATH=./backend/line/assets/richmenu.png
SEATED_DURATION_MINUTES=60
SEATED_WARN_BEFORE_MINUTES=10
ALMOST_CALLED_AHEAD_COUNT=2
# 本機需含顧客 3000 與店員 3001（Windows 可能保留 2943–3042，勿用 3001）
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://pre-ordering-system.vercel.app
ALLOW_BROWSER_QUEUE=1

# Customer (Vercel)
NEXT_PUBLIC_API_URL=http://localhost:8010
NEXT_PUBLIC_LIFF_ID=
NEXT_PUBLIC_LINE_OA_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-oa
